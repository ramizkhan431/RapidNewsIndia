# Database Configuration
# Fallback to SQLite if PostgreSQL is not active
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rapid_news_db

# Security & JWT Configuration
# Generate a secret key using: openssl rand -hex 32
SECRET_KEY=supersecretjwtkeyforrapidnewsindia2026makeitsufficientlylong
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Storage Config
UPLOAD_DIR=static/uploads

# App Config
HOST=0.0.0.0
PORT=8000
